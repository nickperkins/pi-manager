{
  "name": "pi-manager",
  "version": "0.0.1",
  "description": "Desktop manager for pi agentic coding sessions",
  "license": "MIT",
  "author": "Nick Perkins",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build:host && electron-vite build",
    "build:host": "vite build --config vite.host.config.mts",
    "test:host": "npm run build:host && electron-vite build && npx electron out/main/test-host.js --no-sandbox",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "prepare": "husky",
    "lint": "eslint src tests",
    "test:coverage": "vitest run --coverage",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "diff": "^8.0.0",
    "highlight.js": "^11.11.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
